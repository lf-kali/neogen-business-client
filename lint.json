\n\r\n            <form className=\"space-y-5\">\r\n              <NeogenInput\r\n                label=\"Nome completo\"\r\n                type=\"text\"\r\n                id=\"name\"\r\n                name=\"name\"\r\n                placeholder=\"Nome do cliente\"\r\n                labelStyle={darkLabelStyle}\r\n                inputStyle={darkInputStyle}\r\n              />\r\n\r\n              <div className=\"grid gap-5 md:grid-cols-2\">\r\n                <NeogenInput\r\n                  label=\"Email\"\r\n                  type=\"email\"\r\n                  id=\"email\"\r\n                  name=\"email\"\r\n                  placeholder=\"cliente@email.com\"\r\n                  labelStyle={darkLabelStyle}\r\n                  inputStyle={darkInputStyle}\r\n                />\r\n                <NeogenInput\r\n                  label=\"Telefone\"\r\n                  type=\"tel\"\r\n                  id=\"phone\"\r\n                  name=\"phone\"\r\n                  placeholder=\"(11) 99999-0000\"\r\n                  labelStyle={darkLabelStyle}\r\n                  inputStyle={darkInputStyle}\r\n                />\r\n              </div>\r\n\r\n              <div className=\"grid gap-5 md:grid-cols-2\">\r\n                <NeogenInput\r\n                  label=\"CPF\"\r\n                  type=\"text\"\r\n                  id=\"cpf\"\r\n                  name=\"cpf\"\r\n                  placeholder=\"000.000.000-00\"\r\n                  labelStyle={darkLabelStyle}\r\n                  inputStyle={darkInputStyle}\r\n                />\r\n                <NeogenInput\r\n                  label=\"CNPJ (opcional)\"\r\n                  type=\"text\"\r\n                  id=\"cnpj\"\r\n                  name=\"cnpj\"\r\n                  placeholder=\"00.000.000/0001-00\"\r\n                  labelStyle={darkLabelStyle}\r\n                  inputStyle={darkInputStyle}\r\n                />\r\n              </div>\r\n\r\n              <div className=\